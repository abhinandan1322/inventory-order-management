# =====================================================================
# DATABASE SETTINGS (Used by db and backend services)
# =====================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=postgres

# =====================================================================
# FRONTEND SETTINGS (Used during building the React/Vite client)
# =====================================================================
# Point this to the public address of the backend service.
# For local docker-compose running on localhost, use http://localhost:8000
VITE_API_URL=http://localhost:8000
